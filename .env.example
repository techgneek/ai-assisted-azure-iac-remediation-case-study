# Copy this file to .env and replace the placeholder values.
# Never commit .env. It contains secrets.

TENABLE_URL="https://REDACTED_SCANNER_PUBLIC_IP:8834"
TENABLE_ACCESS_KEY="replace_with_your_access_key"
TENABLE_SECRET_KEY="replace_with_your_secret_key"

# Optional: local Nessus UI credentials.
# Needed for Nessus Essentials actions that API keys cannot perform, such as
# creating and launching scans from the local scanner API.
NESSUS_USERNAME="replace_with_your_nessus_username"
NESSUS_PASSWORD="replace_with_your_nessus_password"
